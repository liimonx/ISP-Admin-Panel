# Production Environment Variables
# Copy to .env.prod and fill in with actual values

# Django Settings
DEBUG=False
DJANGO_SETTINGS_MODULE=isp_admin.settings
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,api.yourdomain.com
SECRET_KEY=your-production-secret-key-change-this-to-something-secure

# Database Configuration
DATABASE_URL=postgresql://isp_admin:your_postgres_password@db:5432/isp_admin
POSTGRES_DB=isp_admin
POSTGRES_USER=isp_admin
POSTGRES_PASSWORD=your_postgres_password

# Redis Configuration  
REDIS_URL=redis://:your_redis_password@redis:6379/0
REDIS_PASSWORD=your_redis_password

# JWT Settings
JWT_ACCESS_TOKEN_LIFETIME=5
JWT_REFRESH_TOKEN_LIFETIME=7

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Security Settings
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_CONTENT_TYPE_NOSNIFF=True
X_FRAME_OPTIONS=DENY

# Main Router Configuration
MAIN_ROUTER_IP=your-router-ip
MAIN_ROUTER_API_PORT=8728
MAIN_ROUTER_SSH_PORT=22
MAIN_ROUTER_USERNAME=admin
MAIN_ROUTER_PASSWORD=your-router-password
MAIN_ROUTER_USE_TLS=True
MIKROTIK_MOCK_MODE=False

# Router Health Check
ROUTER_API_TIMEOUT=30
ROUTER_CONNECTION_RETRIES=3
ROUTER_HEALTH_CHECK_INTERVAL=300

# Payment Providers
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_key
BKASH_APP_KEY=your-bkash-app-key
BKASH_APP_SECRET=your-bkash-app-secret
SSLCOMMERZ_STORE_ID=your-sslcommerz-store-id
SSLCOMMERZ_STORE_PASSWORD=your-sslcommerz-password

# SNMP Settings
SNMP_COMMUNITY=your-snmp-community-string
SNMP_TIMEOUT=1
SNMP_RETRIES=3

# Email Configuration (Gmail example)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Superuser Configuration
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@yourdomain.com
DJANGO_SUPERUSER_PASSWORD=your-secure-admin-password

# Rate Limiting
RATE_LIMIT_AUTHENTICATED=200
RATE_LIMIT_ANONYMOUS=60
RATE_LIMIT_LOGIN=10
RATE_LIMIT_PASSWORD_RESET=5

# Connection Settings
CONN_MAX_AGE=60
